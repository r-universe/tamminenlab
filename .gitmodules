[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "blaster"]
	path = blaster
	url = https://github.com/tamminenlab/blaster
	shallow = true
	registered = true
[submodule "prider"]
	path = prider
	url = https://github.com/tamminenlab/prider
	shallow = true
	registered = true
